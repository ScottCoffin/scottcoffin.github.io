{
  "name": "scottcoffin-site",
  "version": "1.0.0",
  "description": "scottcoff.in personal site build and SEO diagnostic scripts",
  "private": true,
  "engines": {
    "node": ">= 18.0.0"
  },
  "devDependencies": {
    "@lhci/cli": "latest",
    "http-server": "latest",
    "lighthouse": "latest",
    "npm-run-all": "^1.7.0",
    "onchange": "^2.2.0",
    "uglify-js": "^2.6.1"
  },
  "scripts": {
    "uglify": "uglifyjs assets/js/vendor/jquery/jquery-3.2.1.min.js assets/js/plugins/jquery.fitvids.js assets/js/plugins/jquery.greedy-navigation.js assets/js/plugins/jquery.magnific-popup.js assets/js/plugins/jquery.smooth-scroll.min.js assets/js/_main.js -c -m -o assets/js/main.min.js",
    "add-banner": "node banner.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify && npm run add-banner",
    "build:site": "bundle exec jekyll build",
    "serve:site": "npx http-server _site -p 4000",
    "lhci": "lhci autorun",
    "psi": "node scripts/pagespeed_insights.mjs",
    "audit:tasks": "node scripts/audit_to_tasks.mjs",
    "diagnose": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/diagnose_seo_perf.ps1",
    "diagnose:live": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:RUN_PSI=1; ./scripts/diagnose_seo_perf.ps1\"",
    "seo:check": "node scripts/local_seo_check.mjs",
    "jsonld": "node scripts/validate_jsonld.mjs",
    "gsc": "node scripts/search_console_check.mjs",
    "gtmetrix": "node scripts/gtmetrix_check.mjs"
  }
}
